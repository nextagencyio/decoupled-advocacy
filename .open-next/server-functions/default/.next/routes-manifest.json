{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/homepage",
      "destination": "/",
      "statusCode": 308,
      "regex": "^(?!/_next)/homepage(?:/)?$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/sites/:path*",
        "destination": "/api/proxy/sites/:path*",
        "regex": "^/sites(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/action-alerts/[...slug]",
      "regex": "^/action\\-alerts/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/action\\-alerts/(?<nxtPslug>.+?)(?:/)?$"
    },
    {
      "page": "/api/proxy/sites/[...path]",
      "regex": "^/api/proxy/sites/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/proxy/sites/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/campaigns/[...slug]",
      "regex": "^/campaigns/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/campaigns/(?<nxtPslug>.+?)(?:/)?$"
    },
    {
      "page": "/issues/[...slug]",
      "regex": "^/issues/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/issues/(?<nxtPslug>.+?)(?:/)?$"
    },
    {
      "page": "/reports/[...slug]",
      "regex": "^/reports/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/reports/(?<nxtPslug>.+?)(?:/)?$"
    },
    {
      "page": "/[...slug]",
      "regex": "^/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/(?<nxtPslug>.+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/action-alerts",
      "regex": "^/action\\-alerts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/action\\-alerts(?:/)?$"
    },
    {
      "page": "/api/graphql",
      "regex": "^/api/graphql(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/graphql(?:/)?$"
    },
    {
      "page": "/api/revalidate",
      "regex": "^/api/revalidate(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/revalidate(?:/)?$"
    },
    {
      "page": "/apple-icon",
      "regex": "^/apple\\-icon(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/apple\\-icon(?:/)?$"
    },
    {
      "page": "/campaigns",
      "regex": "^/campaigns(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/campaigns(?:/)?$"
    },
    {
      "page": "/icon.svg",
      "regex": "^/icon\\.svg(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon\\.svg(?:/)?$"
    },
    {
      "page": "/issues",
      "regex": "^/issues(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/issues(?:/)?$"
    },
    {
      "page": "/reports",
      "regex": "^/reports(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/reports(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}